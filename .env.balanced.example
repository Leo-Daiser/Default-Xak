# Balanced profile: local hybrid retrieval with CPU-friendly MiniLM embeddings.
# Final compliance provider should be RouterAI/offline if required by organizers.
# Current built-in cloud-provider example uses Mistral; do not put keys here.
RUNTIME_PROFILE=balanced_hybrid
RESOURCE_STRICT=false
RESOURCE_MAX_IMAGE_GB=5

EXTRA_REQUIREMENTS=requirements-embeddings.txt
RETRIEVAL_MODE=hybrid
ENABLE_LOCAL_EMBEDDINGS=true
EAGER_LOCAL_EMBEDDINGS=false
DIRECT_QDRANT_PROJECTION=false
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
ENABLE_LLM=true
LLM_PROVIDER=mistral
ANSWER_SYNTHESIS_MODE=hybrid
EXTRACTION_MODE=deterministic
EXTRACTION_ENABLE_LLM=false
