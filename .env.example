# Example environment configuration for the hackathon project

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=documents

# Neo4j
# Local host run: bolt://localhost:7687
# Docker compose network: bolt://neo4j:7687
KG_BACKEND=auto
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j

# Parser/extraction/answer runtime
PARSER_BACKEND=auto
EXTRACTION_MODE=hybrid
ANSWER_SYNTHESIS_MODE=hybrid

# Embedding models
EMBEDDING_MODEL=BAAI/bge-m3
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# Chunking
CHUNK_SIZE=400
CHUNK_OVERLAP=50

# Data directory for uploaded files
DATA_DIR=data
# Operational metadata / outbox
METADATA_DB_PATH=data/outbox.sqlite3
CATALOG_DB_PATH=data/catalog.sqlite3
DIRECT_QDRANT_PROJECTION=false

# Streamlit UI backend URL
API_BASE=http://localhost:8000

# Retrieval modes: bm25 | embedding | hybrid
RETRIEVAL_MODE=hybrid
# CPU/GPU local dense index without Qdrant. Requires sentence-transformers and cached/downloadable model.
ENABLE_LOCAL_EMBEDDINGS=false
# Deterministic synonym expansion for Russian/English technical terms.
RETRIEVAL_QUERY_EXPANSION=true

# Optional grounded LLM answer synthesis through OpenRouter/OpenAI-compatible APIs.
# Do not commit a real key. If OPENROUTER_API_KEY and OPENROUTER_MODEL are set,
# provider/base_url are resolved automatically.
LLM_ENABLED=false
# Backward-compatible alias:
ENABLE_LLM=false
# Values: none | ollama | openai_compatible | openrouter | groq
LLM_PROVIDER=openrouter
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=your_openrouter_model_slug_here
LLM_API_KEY=your_openrouter_key_here
LLM_REFERER=http://localhost:8501
LLM_APP_TITLE=Scientific Knowledge Graph Demo
LLM_TIMEOUT_SECONDS=20

# OpenRouter aliases
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL=your_openrouter_model_slug_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Free/cloud examples:
# OpenRouter: LLM_PROVIDER=openrouter; LLM_MODEL=openrouter/free; LLM_API_KEY=sk-or-...
# Groq:       LLM_PROVIDER=groq;       LLM_MODEL=llama-3.3-70b-versatile; LLM_API_KEY=gsk_...
